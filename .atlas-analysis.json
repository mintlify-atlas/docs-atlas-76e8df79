  "keyFeatures": [
    "DMX512, Art-Net, sACN (E1.31) protocol support",
    "1700+ fixture definitions for moving heads, scanners, and dimmers",
    "Virtual Console with customizable widgets and cue lists",
    "Scene, Chaser, EFX, and RGB Matrix function types",
    "Show Manager for timeline-based programming",
    "2D and 3D visualization of lighting setup",
    "Web-based remote control interface",
    "MIDI and OSC input/output support",
    "Audio triggers and beat detection",
    "Cross-platform (Linux, Windows, macOS, Raspberry Pi)"
  ],
  "publicApiSurface": [
    "Doc - Main document/workspace class",
    "Fixture - Lighting fixture representation",
    "Function - Base class for all function types",
    "Scene - Static lighting scene",
    "Chaser - Sequential step list",
    "Sequence - Chaser linked to a scene",
    "EFX - Effects generator for moving heads",
    "RGBMatrix - Pixel mapping and animations",
    "Collection - Function group launcher",
    "Show - Timeline-based show",
    "InputOutputMap - Universe mapping",
    "MasterTimer - Timing engine",
    "VCWidget - Virtual console widget base",
    "QLCChannel - Fixture channel definition",
    "QLCCapability - Channel capability range",
    "QLCFixtureDef - Fixture definition"
  ]
